rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core rule definition:
    // This allows any authenticated user (including new Admin registrations and standard users)
    // to freely and natively read and interact with their real-time databases.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
  }
}
